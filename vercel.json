{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/logo.png", "dest": "schedule_agent_web/static/logo.png" },
    { "src": "/assets/(.*)", "dest": "schedule_agent_web/static/assets/$1" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}
