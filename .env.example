# VueLogic Beta V0.3 — copy to .env and set values (do not commit .env).

# --- LLM Chat Provider (set at least ONE) ---
# Option A: Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Option B: OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# --- Authentication ---
# JWT secret (auto-generated if not set; set for consistent sessions across deploys)
# VUELOGIC_JWT_SECRET=your-random-64-char-hex-string

# --- Vercel deployment ---
# Set these as Vercel Environment Variables (Settings > Environment Variables):
#   OPENAI_API_KEY    or  ANTHROPIC_API_KEY
#   VUELOGIC_JWT_SECRET

# --- Vector store (optional, for semantic search) ---
# QDRANT_URL=https://xxxx.aws.cloud.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key

# --- Persistence (optional, Vercel uses Upstash Redis) ---
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
